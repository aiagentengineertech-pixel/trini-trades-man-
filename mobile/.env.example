# Copy this file to ".env" and fill in your values from the Supabase dashboard
# (Project Settings → API). The EXPO_PUBLIC_ prefix is required for Expo to
# expose these to the app at runtime.
EXPO_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=YOUR-ANON-PUBLIC-KEY
