# Supabase project URL (same project as the mobile app)
SUPABASE_URL=https://bhlflhyojzjzoksejekc.supabase.co

# Anon/publishable key — used ONLY to validate incoming user JWTs.
SUPABASE_ANON_KEY=sb_publishable_xxx

# Service role key — FULL ADMIN ACCESS, bypasses RLS. Keep server-side only.
# Supabase Dashboard -> Project Settings -> API -> service_role (secret).
SUPABASE_SERVICE_ROLE_KEY=eyJ...service_role...

# Port for the admin API
PORT=8787

# Comma-separated allowed origins for the admin web page (CORS)
ADMIN_ORIGIN=http://localhost:5173
